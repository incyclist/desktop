{
  "name": "incyclist",
  "productName": "Incyclist",
  "version": "0.9.14",
  "copyright": "Guido Doumen, Jeroen Doumen",
  "description": "Incyclist Desktop App",
  "main": "src/main.js",
  "scripts": {
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:all": "jest --config jest.integration.config.js && jest",
    "bletest": "node scripts/ble",
    "coverage": "jest --coverage",
    "app-test": "playwright test --workers 1",
    "start": "electron ./",
    "forge-start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make-linux": "electron-builder --linux --config ./config/linux64-installer.json",
    "make-linux-arm": "electron-builder --linux --arm64 --config ./config/linuxarm64-installer.json",
    "make-mac-appstore": "export BUILD_TARGET=appstore && electron-forge make",
    "make-mac-dist": "export BUILD_TARGET=incyclist && electron-forge make",
    "make-mac-dist-arm": "export BUILD_TARGET=incyclist && electron-forge make --arch arm64",
    "make-windows-dist": "SET BUILD_TARGET=dist && electron-forge make"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/incyclist/ergoapp"
  },
  "author": "Guido Doumen, Jeroen Doumen",
  "homepage": "https://incyclist.com",
  "license": "MIT",
  "gypfile": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@serialport/bindings-cpp": "^10.8.0",
    "@stoprocent/noble": "^1.19.1",
    "axios": "^1.13.6",
    "bonjour-service": "^1.3.0",
    "chrome-native-messaging": "^0.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-unhandled": "^5.0.0",
    "electron-updater": "^6.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "gd-eventlog": "^0.1.27",
    "incyclist-ant-plus": "^0.3.6",
    "mp4frag": "^0.7.0",
    "mqtt": "^5.15.0",
    "serialport": "^10.5.0",
    "update-electron-app": "^3.1.2",
    "usb": "^2.17.0",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-pkg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-snap": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.3",
    "@mapbox/node-pre-gyp": "^2.0.3",
    "@playwright/test": "^1.58.2",
    "axios-mock-adapter": "^2.1.0",
    "bindings": "^1.5.0",
    "dotenv": "^17.3.1",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "form-data": "^4.0.5",
    "incyclist-devices": "^3.0.9",
    "jest": "^30.2.0",
    "lnk": "^1.1.0",
    "node-abi": "^4.26.0"
  }
}
